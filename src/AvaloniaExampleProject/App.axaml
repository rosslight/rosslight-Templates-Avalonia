<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvaloniaExampleProject.App"
             xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <styling:FluentAvaloniaTheme PreferSystemTheme="True" PreferUserAccentColor="True" />
        <Style Selector="SelectableTextBlock">
            <Setter Property="SelectionBrush" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <!-- Necessary for the TitleBar Buttons to extend to the desired height with FluentAvalonia v3-->
        <Style Selector="WindowDrawnDecorations">
            <Setter Property="DefaultTitleBarHeight" Value="44"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AvaloniaExampleProject/Styling/Resources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
