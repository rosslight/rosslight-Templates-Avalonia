<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:AvaloniaExampleProject.Features.Welcome"
    xmlns:designTime="clr-namespace:AvaloniaExampleProject.Shell.DesignTime"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="AvaloniaExampleProject.Features.Welcome.WelcomeView"
    x:DataType="viewModels:WelcomeViewModel"
    Design.DataContext="{x:Static designTime:DesignData.WelcomeViewModel}"
>
    <StackPanel Orientation="Vertical" Margin="24,18,24,48" Spacing="8">
        <TextBlock Text="{CompiledBinding I18N.Welcome_Title}" FontSize="28" FontWeight="SemiBold" />
        <TextBlock Text="{CompiledBinding I18N.Welcome_Greeting}" />
        <Button Content="{CompiledBinding I18N.Welcome_ClickMe}" Command="{CompiledBinding ShowInputDialogCommand}" />
    </StackPanel>
</UserControl>
