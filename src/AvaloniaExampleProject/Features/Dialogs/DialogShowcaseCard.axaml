<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:AvaloniaExampleProject.Features.Dialogs"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
>
    <Design.PreviewWith>
        <dialogs:DialogShowcaseCard
            Height="500"
            Title="MessageBoxDialog"
            Description="Show a clear status message after an action."
            Icon="Message"
            IconBrush="#0F78D4"
            ButtonText="Run demo"
        />
    </Design.PreviewWith>

    <Style Selector="dialogs|DialogShowcaseCard">
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Width="252"
                    Padding="20"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                >
                    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="Auto,*">
                        <controls:FASymbolIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            Height="36"
                            FontSize="36"
                            Symbol="{TemplateBinding Icon}"
                            Foreground="{TemplateBinding IconBrush}"
                        />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="8,0,8,0"
                            VerticalAlignment="Center"
                            Text="{TemplateBinding Title}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            TextWrapping="Wrap"
                        />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,12,0,18"
                            Text="{TemplateBinding Description}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                        />

                        <Button
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalAlignment="Bottom"
                            Command="{TemplateBinding Command}"
                        >
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:FASymbolIcon Width="14" Height="14" FontSize="14" Symbol="Play" />
                                <TextBlock Text="{TemplateBinding ButtonText}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
